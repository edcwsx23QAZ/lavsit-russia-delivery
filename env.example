# Database Configuration (Supabase PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/database?schema=public"
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"

# PEK API Configuration
PEK_LOGIN="your-pek-login"
PEK_API_KEY="your-pek-api-key"

# KIT API Configuration (optional)
KIT_API_TOKEN="your-kit-api-token"

# Google Sheets Sync (Delivery CRM)
# Получите URL после развертывания Google Apps Script как Web App
# См. инструкцию: docs/google-sheets-sync-setup.md
NEXT_PUBLIC_GOOGLE_APPS_SCRIPT_URL="https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec"

